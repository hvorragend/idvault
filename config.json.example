{
  "SECRET_KEY": "BITTE_ERSETZEN_mindestens_32_Zeichen",

  "PORT": 5000,

  "IDV_HTTPS": 0,
  "IDV_SSL_CERT": "instance/certs/cert.pem",
  "IDV_SSL_KEY": "instance/certs/key.pem",
  "IDV_SSL_AUTOGEN": 1,

  "IDV_DB_PATH": "instance/idvault.db",
  "IDV_INSTANCE_PATH": "instance",

  "IDV_SMTP_HOST": "",
  "IDV_SMTP_PORT": 587,
  "IDV_SMTP_USER": "",
  "IDV_SMTP_PASSWORD": "",
  "IDV_SMTP_FROM": "",
  "IDV_SMTP_TLS": 1,
  "IDV_APP_BASE_URL": "",

  "_kommentar_sicherheit": "Folgende Schalter steuern Sicherheitsfunktionen – vor Produktivbetrieb unbedingt anpassen.",

  "IDV_ALLOW_SIDECAR_UPDATES": 1,
  "_kommentar_sidecar": "Auf 0 setzen, um das Hochladen von Sidecar-Updates (Admin → Update) komplett zu deaktivieren. Empfohlen in regulierten Umgebungen oder wenn Updates ausschließlich über neue EXE-Builds erfolgen sollen.",

  "IDV_LOCAL_USERS": [
    {
      "_hinweis": "Beispiel-Eintrag (auskommentieren oder entfernen). Passwort-Hash erzeugen mit: python -c \"from werkzeug.security import generate_password_hash; print(generate_password_hash('mein-passwort', method='pbkdf2:sha256'))\"",
      "username": "admin",
      "password_hash": "pbkdf2:sha256:600000$REPLACE$REPLACE",
      "name": "Administrator",
      "role": "IDV-Administrator",
      "person_id": null
    }
  ],
  "_kommentar_users": "Lokale Benutzer werden aus dieser Liste gelesen. Rollen: IDV-Administrator, IDV-Koordinator, IDV-Entwickler, Fachverantwortlicher, Revision, IT-Sicherheit. Wenn LDAP aktiv ist, bleibt diese Liste als Fallback bestehen (z.B. für Break-Glass-Admin). Leere Liste = kein lokaler Login.",

  "IDV_LOGIN_RATE_LIMIT": "5 per minute;30 per hour",
  "_kommentar_ratelimit": "Flask-Limiter-Syntax. Gilt pro Client-IP am POST /login.",

  "IDV_UPLOAD_RATE_LIMIT": "10 per minute;60 per hour",
  "_kommentar_uploadlimit": "Rate-Limit für Admin-Uploads (Update-ZIP, CSV-Importe). Pro Client-IP.",

  "scanner": {
    "scan_paths": [],
    "extensions": [
      ".xls", ".xlsx", ".xlsm", ".xlsb", ".xltm", ".xltx",
      ".accdb", ".mdb", ".accde", ".accdr",
      ".ida", ".idv",
      ".bas", ".cls", ".frm",
      ".pbix", ".pbit",
      ".dotm", ".pptm",
      ".py", ".r", ".rmd",
      ".sql"
    ],
    "exclude_paths": [
      "~$",
      ".tmp",
      "$RECYCLE.BIN",
      "System Volume Information",
      "AppData"
    ],
    "db_path": "instance/idvault.db",
    "log_path": "instance/logs/idv_scanner.log",
    "hash_size_limit_mb": 500,
    "max_workers": 4,
    "move_detection": "name_and_hash",
    "scan_since": null,
    "read_file_owner": true
  }
}
