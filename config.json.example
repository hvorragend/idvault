{
  "_kommentar_praezedenz": "Präzedenz der Konfigurationsquellen (höchste zuerst): Umgebungsvariable > config.json > SQLite (app_settings / ldap_config) > Hardcoded-Default. Die Web-UI speichert in die SQLite-DB. Ein Eintrag hier überschreibt den DB-Wert und macht das entsprechende Feld in der Web-UI read-only.",

  "SECRET_KEY": "BITTE_ERSETZEN_mindestens_32_Zeichen",

  "PORT": 5000,

  "IDV_HTTPS": 0,
  "IDV_SSL_CERT": "instance/certs/cert.pem",
  "IDV_SSL_KEY": "instance/certs/key.pem",
  "IDV_SSL_AUTOGEN": 1,

  "IDV_DB_PATH": "instance/idvault.db",
  "IDV_INSTANCE_PATH": "instance",

  "_kommentar_smtp": "SMTP-Zugangsdaten werden über die Web-UI unter /admin/mail in der SQLite-Tabelle app_settings gespeichert. Daher sind hier keine SMTP-Keys mehr vorbelegt. Frühere Einträge wie IDV_SMTP_HOST wurden von der Anwendung nie gelesen und dienen nur als Umgebungsvariable.",

  "_kommentar_sicherheit": "Folgende Schalter steuern Sicherheitsfunktionen – vor Produktivbetrieb unbedingt anpassen.",

  "IDV_ALLOW_SIDECAR_UPDATES": 1,
  "_kommentar_sidecar": "Auf 0 setzen, um das Hochladen von Sidecar-Updates (Admin → Update) komplett zu deaktivieren. Empfohlen in regulierten Umgebungen oder wenn Updates ausschließlich über neue EXE-Builds erfolgen sollen.",

  "IDV_SERVICE_NAME": "",
  "_kommentar_service": "Windows-Dienstname (interner Name, wie bei 'sc create' angegeben, z. B. 'idvault'). Wenn gesetzt, löst 'App neu starten' in der Web-UI einen sauberen Dienst-Neustart via 'sc start <name>' aus, statt eine neue EXE-Instanz direkt zu spawnen. Das Dienstkonto benötigt das Recht SERVICE_START für den eigenen Dienst (bei LOCAL SYSTEM standardmäßig vorhanden). Leer lassen = Direktmodus (EXE wird als neues Konsolenfenster gestartet).",

  "IDV_LOCAL_USERS": [
    {
      "_hinweis": "Variante A (empfohlen) – Passwort-Hash. Erzeugen mit: python -c \"from werkzeug.security import generate_password_hash; print(generate_password_hash('mein-passwort', method='pbkdf2:sha256'))\"",
      "username": "admin",
      "password_hash": "pbkdf2:sha256:600000$REPLACE$REPLACE",
      "name": "Administrator",
      "role": "IDV-Administrator",
      "person_id": null
    },
    {
      "_hinweis": "Variante B (bequem) – Klartext-Passwort. Wird beim Start automatisch gehasht, das Klartext-Feld wird NICHT für den Login wiederverwendet. Schütze config.json mit Dateisystemrechten (NTFS-ACL bzw. Unix 0640).",
      "username": "notfall-admin",
      "password": "bitte-aendern",
      "name": "Notfall-Administrator",
      "role": "IDV-Administrator",
      "person_id": null
    }
  ],
  "_kommentar_users": "Lokale Benutzer werden aus dieser Liste gelesen. Rollen: IDV-Administrator, IDV-Koordinator, IDV-Entwickler, Fachverantwortlicher, Revision, IT-Sicherheit. Pro Eintrag entweder 'password_hash' (empfohlen) oder 'password' (Klartext, optional) angeben – liegt beides vor, gewinnt der Hash. Reihenfolge beim lokalen Login: LDAP (falls aktiv) → config.json → persons-Tabelle. Ein hier gepflegter Eintrag überschreibt damit bewusst einen gleichnamigen DB-Benutzer (z.B. für Break-Glass-Admin trotz vorhandener persons-Zeile); der Konflikt wird in idvault.log protokolliert. Leere Liste = kein lokaler Login.",

  "IDV_LOGIN_RATE_LIMIT": "5 per minute;30 per hour",
  "_kommentar_ratelimit": "Flask-Limiter-Syntax. Gilt pro Client-IP am POST /login.",

  "IDV_UPLOAD_RATE_LIMIT": "10 per minute;60 per hour",
  "_kommentar_uploadlimit": "Rate-Limit für Admin-Uploads (Update-ZIP, CSV-Importe). Pro Client-IP.",

  "scanner": {
    "scan_paths": [],
    "extensions": [
      ".xls", ".xlsx", ".xlsm", ".xlsb", ".xltm", ".xltx",
      ".accdb", ".mdb", ".accde", ".accdr",
      ".ida", ".idv",
      ".bas", ".cls", ".frm",
      ".pbix", ".pbit",
      ".dotm", ".pptm",
      ".py", ".r", ".rmd",
      ".sql"
    ],
    "exclude_paths": [
      "~$",
      ".tmp",
      "$RECYCLE.BIN",
      "System Volume Information",
      "AppData"
    ],
    "db_path": "instance/idvault.db",
    "log_path": "instance/logs/idv_scanner.log",
    "hash_size_limit_mb": 500,
    "max_workers": 4,
    "move_detection": "name_and_hash",
    "scan_since": null,
    "read_file_owner": true
  },

  "_kommentar_teams": "Teams-Scanner (SharePoint/Graph-API). Ersetzt die frühere scanner/teams_config.json – die wird beim nächsten Start automatisch nach config.json['teams'] migriert und zu teams_config.json.migrated umbenannt. Die Web-UI unter /admin/teams-einstellungen schreibt direkt hier hinein.",

  "teams": {
    "tenant_id": "",
    "client_id": "",
    "client_secret": "",
    "extensions": [
      ".xls", ".xlsx", ".xlsm", ".xlsb", ".xltm", ".xltx",
      ".accdb", ".mdb", ".accde", ".accdr",
      ".ida", ".idv",
      ".pbix", ".pbit",
      ".dotm", ".pptm",
      ".py", ".r", ".rmd", ".sql"
    ],
    "hash_size_limit_mb": 100,
    "download_for_ooxml": true,
    "move_detection": "name_and_hash",
    "teams": []
  },

  "_kommentar_ldap": "OPTIONAL. Der 'ldap'-Block überschreibt pro Feld die SQLite-Tabelle ldap_config. Fehlt er (oder einzelne Keys), gelten die in /admin/ldap-config gepflegten DB-Werte. Überschriebene Felder sind in der Web-UI read-only. bind_password darf Klartext sein oder 'ENV:VARNAME' referenzieren – so managen Ops-Teams das Secret extern, ohne die Fernet-Verschlüsselung der DB zu benötigen.",

  "_ldap_beispiel": {
    "enabled": true,
    "server_url": "ldaps://ad.example.com",
    "port": 636,
    "base_dn": "DC=example,DC=com",
    "bind_dn": "CN=svc-idvault,OU=ServiceAccounts,DC=example,DC=com",
    "bind_password": "ENV:IDV_LDAP_BIND_PASSWORD",
    "user_attr": "sAMAccountName",
    "ssl_verify": true
  }
}
